{
    "name": "regreplace",
    "displayName": "regreplace",
    "description": "Regular expressions replacing befor save.",
    "version": "1.4.0",
    "publisher": "DomiR",
    "license": "MIT",
    "homepage": "https://github.com/DomiR/vscode-regreplace/blob/master/README.md",
    "repository": {
        "type": "git",
        "url": "https://github.com/DomiR/vscode-regreplace.git"
    },
    "galleryBanner": {
        "color": "#2980b9",
        "theme": "dark"
    },
    "icon": "assets/logo.png",
    "bugs": {
        "url": "https://github.com/DomiR/vscode-regreplace/issues"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Languages",
        "Other"
    ],
    "keywords": [
        "ES6",
        "ES2015",
        "OnSave",
        "Replace"
    ],
    "activationEvents": [
        "*"
    ],
    "main": "./out/src/extension",
    "contributes": {
        "commands": [
            {
                "command": "regreplace.regreplace",
                "title": "RegReplace: Run all"
            },
            {
                "command": "regreplace.run-selected-rules",
                "title": "RegReplace: Run selected rules"
            },
            {
                "command": "regreplace.run-on-workspace",
                "title": "RegReplace: Run on workspace..."
            },
            {
                "command": "regreplace.run-on-folder",
                "title": "RegReplace: Run on folder..."
            },
            {
                "command": "regreplace.save-without-regreplace",
                "title": "RegReplace: Save without replacing"
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "command": "regreplace.run-on-folder",
                    "when": "explorerResourceIsFolder",
                    "group": "7_modification@1"
                }
            ]
        },
        "configuration": {
            "title": "Regreplace configuration",
            "properties": {
                "regreplace.on-save": {
                    "type": "boolean",
                    "default": true,
                    "description": "Regreplace on save."
                },
                "regreplace.suppress-warnings": {
                    "type": "boolean",
                    "default": false,
                    "description": "Suppress warnings when regreplace fails."
                },
                "regreplace.bulk-include": {
                    "type": "string",
                    "default": "**/*",
                    "description": "Glob for files included in workspace/folder bulk operations."
                },
                "regreplace.bulk-exclude-globs": {
                    "type": "array",
                    "default": [
                        "**/.git/**",
                        "**/node_modules/**",
                        "**/.svn/**",
                        "**/.hg/**",
                        "**/dist/**",
                        "**/out/**",
                        "**/build/**",
                        "**/.next/**",
                        "**/.nuxt/**",
                        "**/.svelte-kit/**",
                        "**/.angular/**",
                        "**/.docusaurus/**",
                        "**/.cache/**",
                        "**/.parcel-cache/**",
                        "**/.vite/**",
                        "**/.turbo/**",
                        "**/.eslintcache/**",
                        "**/__pycache__/**",
                        "**/.pytest_cache/**",
                        "**/.mypy_cache/**",
                        "**/.ruff_cache/**",
                        "**/.tox/**",
                        "**/.venv/**",
                        "**/venv/**",
                        "**/.npm/**",
                        "**/.yarn/**",
                        "**/.pnpm-store/**",
                        "**/bower_components/**",
                        "**/target/**",
                        "**/.gradle/**",
                        "**/.idea/**",
                        "**/.vs/**",
                        "**/coverage/**",
                        "**/.nyc_output/**",
                        "**/.vscode-test/**",
                        "**/.terraform/**",
                        "**/.serverless/**",
                        "**/*.egg-info/**"
                    ],
                    "items": {
                        "type": "string"
                    },
                    "description": "Path globs excluded from bulk operations (cache folders, dependencies, build output)."
                },
                "regreplace.bulk-exclude": {
                    "type": "string",
                    "default": "",
                    "description": "Legacy glob exclude string (merged with bulk-exclude-globs). Prefer bulk-exclude-globs."
                },
                "regreplace.bulk-exclude-extensions": {
                    "type": "array",
                    "default": [
                        ".png",
                        ".jpg",
                        ".jpeg",
                        ".gif",
                        ".webp",
                        ".ico",
                        ".bmp",
                        ".tif",
                        ".tiff",
                        ".heic",
                        ".avif",
                        ".mp3",
                        ".mp4",
                        ".wav",
                        ".ogg",
                        ".webm",
                        ".avi",
                        ".mov",
                        ".mkv",
                        ".flac",
                        ".pdf",
                        ".zip",
                        ".gz",
                        ".tar",
                        ".rar",
                        ".7z",
                        ".bz2",
                        ".xz",
                        ".jar",
                        ".war",
                        ".exe",
                        ".dll",
                        ".so",
                        ".dylib",
                        ".bin",
                        ".dat",
                        ".wasm",
                        ".class",
                        ".pyc",
                        ".pyo",
                        ".o",
                        ".a",
                        ".lib",
                        ".obj",
                        ".woff",
                        ".woff2",
                        ".ttf",
                        ".otf",
                        ".eot",
                        ".sqlite",
                        ".sqlite3",
                        ".db"
                    ],
                    "items": {
                        "type": "string"
                    },
                    "description": "File extensions excluded from bulk operations (include the dot, e.g. \".png\")."
                },
                "regreplace.bulk-exclude-mime-types": {
                    "type": "array",
                    "default": [
                        "image/*",
                        "audio/*",
                        "video/*",
                        "font/*",
                        "application/octet-stream",
                        "application/pdf",
                        "application/zip",
                        "application/gzip",
                        "application/x-gzip",
                        "application/x-tar",
                        "application/x-7z-compressed",
                        "application/x-rar-compressed",
                        "application/java-archive",
                        "application/wasm"
                    ],
                    "items": {
                        "type": "string"
                    },
                    "description": "Mime types excluded from bulk operations. Supports wildcards (e.g. \"image/*\")."
                },
                "regreplace.bulk-text-only": {
                    "type": "boolean",
                    "default": true,
                    "description": "Skip files that look binary (contain null bytes). Catches non-text files without a known extension."
                },
                "regreplace.commands": {
                    "type": "array",
                    "default": [],
                    "description": "Replace commands.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "Command name for debugging.",
                                "default": ".*"
                            },
                            "language": {
                                "type": [
                                    "string",
                                    "array"
                                ],
                                "items": {
                                    "type": "string"
                                },
                                "description": "LanguageId used instead of match, (exclude will still work) e.g. \"typescript\"",
                                "default": "javascript"
                            },
                            "match": {
                                "type": [
                                    "string",
                                    "array"
                                ],
                                "items": {
                                    "type": "string"
                                },
                                "description": "Regex for matching files to run commands on. e.g. \"\\.(ts|js|tsx)$\"",
                                "default": ".*"
                            },
                            "exclude": {
                                "type": [
                                    "string",
                                    "array"
                                ],
                                "items": {
                                    "type": "string"
                                },
                                "description": "Regex for matching files *not* to run commands on. e.g. \"^\\.$\" exclude dot files",
                                "default": ""
                            },
                            "priority": {
                                "type": "number",
                                "description": "Command priority determines order.",
                                "default": 0
                            },
                            "find": {
                                "type": "string",
                                "description": "Use simple find command. e.g. \"** what\"",
                                "default": ""
                            },
                            "regexp": {
                                "type": "string",
                                "description": "Use regexp find command. Needs to be escaped. e.g. \"(\\n)*\"",
                                "default": ""
                            },
                            "replace": {
                                "type": "string",
                                "description": "Replace text. Supports groups. e.g. \"$2\n$1\"",
                                "default": ""
                            },
                            "global": {
                                "type": "boolean",
                                "description": "Run command asynchronously.",
                                "default": false
                            }
                        }
                    }
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "tsc -p ./",
        "compile": "tsc -watch -p ./",
        "release": "vsce publish",
        "minor": "vsce publish minor",
        "package": "vsce package",
        "test": "mocha"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "mocha": "^10.0.0",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "diff-match-patch": "^1.0.0"
    }
}